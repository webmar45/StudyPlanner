{
  "info": {
    "name": "Smart Study Planner APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:8080/api/auth/register" },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Aarav\",\n  \"email\": \"aarav@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "url": { "raw": "http://localhost:8080/api/auth/login" },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"aarav@example.com\",\n  \"password\": \"password123\"\n}"
        }
      }
    },
    {
      "name": "Create Task",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": { "raw": "http://localhost:8080/api/tasks" },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Chapter 5 Revision\",\n  \"subject\": \"Math\",\n  \"date\": \"2026-04-24\",\n  \"duration\": 90,\n  \"priority\": \"HIGH\",\n  \"status\": \"PENDING\"\n}"
        }
      }
    },
    {
      "name": "Start Study Session",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": { "raw": "http://localhost:8080/api/session/start" }
      }
    },
    {
      "name": "End Study Session",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": { "raw": "http://localhost:8080/api/session/end" }
      }
    },
    {
      "name": "Analytics",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{jwtToken}}" }
        ],
        "url": { "raw": "http://localhost:8080/api/analytics" }
      }
    }
  ]
}
