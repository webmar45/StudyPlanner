# Set these in your hosting provider or CI secrets (never commit real values).
# Spring Boot maps these via application.properties.

# Frontend (Vite): set at build time, e.g. VITE_API_BASE_URL=https://your-api.example.com/api
# VITE_API_BASE_URL=http://localhost:8080/api

MONGODB_URI=mongodb://localhost:27017/smart_study_planner
JWT_SECRET=replace-with-a-long-random-secret-in-production
JWT_EXPIRATION_MS=86400000
PORT=8080
# Comma-separated; must include your deployed frontend URL(s)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
YOUTUBE_API_KEY=
